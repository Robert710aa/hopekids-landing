# Multi-Exchange Bot – przykładowa konfiguracja
# Skopiuj do .env i uzupełnij

# Tryb: dry_run | testnet | prod
BOT_MODE=dry_run

# Giełdy (po przecinku)
BOT_EXCHANGES=binance,bybit

# Symbole (perpetuals)
BOT_SYMBOLS=BTCUSDT,ETHUSDT

# Binance – WS domyślnie prod (testnet często 502). REST z BINANCE_TESTNET.
BINANCE_TESTNET=true
BINANCE_WS_USE_PROD=true
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Bybit (testnet: https://testnet.bybit.com)
BYBIT_TESTNET=true
BYBIT_API_KEY=
BYBIT_API_SECRET=

# Limity ryzyka
RISK_MAX_POSITION_USDT=1000
RISK_MAX_LEVERAGE=5
RISK_MAX_DAILY_LOSS_USDT=200
RISK_MAX_ORDERS_PER_MINUTE=10
RISK_CIRCUIT_BREAKER_SEC=60

# MT5 – opcjonalny zapis sygnału (format jak Signal Hub)
MT5_SIGNAL_ENABLED=false
MT5_SIGNAL_FILE_PATH=

# Detektory (true/false)
DETECTOR_MOMENTUM=true
DETECTOR_ANOMALY=true
DETECTOR_ARBITRAGE=true
