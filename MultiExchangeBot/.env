# Multi-Exchange Bot – konfiguracja (wyedytuj w razie potrzeby)

BOT_MODE=dry_run
BOT_EXCHANGES=binance,bybit
BOT_SYMBOLS=BTCUSDT,ETHUSDT

BINANCE_TESTNET=true
BINANCE_WS_USE_PROD=true
BINANCE_API_KEY=
BINANCE_API_SECRET=

BYBIT_TESTNET=true
BYBIT_WS_USE_PROD=true
BYBIT_API_KEY=
BYBIT_API_SECRET=

RISK_MAX_POSITION_USDT=1000
RISK_MAX_LEVERAGE=5
RISK_MAX_DAILY_LOSS_USDT=200
RISK_MAX_ORDERS_PER_MINUTE=10
RISK_CIRCUIT_BREAKER_SEC=60

MT5_SIGNAL_ENABLED=true
MT5_SIGNAL_FILE_PATH=C:\Users\Crypt\AppData\Roaming\MetaQuotes\Terminal\Common\Files\signal_xau.txt

DETECTOR_MOMENTUM=true
DETECTOR_ANOMALY=true
DETECTOR_ARBITRAGE=true
