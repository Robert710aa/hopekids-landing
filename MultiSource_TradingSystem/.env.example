# Skopiuj do .env i uzupełnij klucze API

# TradingView – webhook URL (alert wysyła POST tutaj)
# W TradingView: Alert → Webhook URL = http://TWOJ_IP:8000/webhook/tradingview

# Alpha Vantage (darmowy klucz: https://www.alphavantage.co/support/#api-key)
ALPHA_VANTAGE_API_KEY=

# Twelve Data (https://twelvedata.com/)
TWELVE_DATA_API_KEY=

# Polygon.io (https://polygon.io/)
POLYGON_API_KEY=

# Binance (opcjonalnie – publiczne API bez klucza do odczytu cen)
# BINANCE_API_KEY=
# BINANCE_API_SECRET=

# Coinbase (opcjonalnie)
# COINBASE_API_KEY=
# COINBASE_API_SECRET=

# Ścieżka do pliku sygnału dla MT5 (np. folder Files w MT5)
# W Windows np.: C:\Users\...\AppData\Roaming\MetaQuotes\Terminal\...\MQL5\Files
SIGNAL_FILE_PATH=./output/signal_xau.txt

# Symbol docelowy (XAU, GOLD, itd.)
SYMBOL=XAUUSD
