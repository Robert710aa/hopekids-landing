{
  "installCommand": "cd hopekids-react && npm install",
  "buildCommand": "cd hopekids-react && npm run build",
  "outputDirectory": "hopekids-react/dist",
  "headers": [
    {
      "source": "/",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/index.html",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    }
  ]
}
